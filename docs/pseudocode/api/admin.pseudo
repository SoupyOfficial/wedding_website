// app/api/v1/admin/ — Admin API Routes
// Purpose: CRUD operations for all content types, protected by auth middleware
// All routes require authenticated session (enforced in middleware.ts)

// ═══════════════════════════════════════════════════════════════════
// PATTERN: Nearly all admin routes follow this identical structure
// ═══════════════════════════════════════════════════════════════════
//
// GET  /admin/{resource}      → SELECT * FROM {table} ORDER BY {sort} → successResponse
// POST /admin/{resource}      → validate body → INSERT → return 201
// GET  /admin/{resource}/[id] → SELECT WHERE id → 404 or return
// PUT  /admin/{resource}/[id] → validate body → dynamic UPDATE → return updated
// DELETE /admin/{resource}/[id] → DELETE WHERE id → return { deleted: true }
//
// SIMPLIFICATION: 80%+ of admin routes share this pattern.
// A generic CRUD handler could eliminate ~10 nearly-identical route files.
// ═══════════════════════════════════════════════════════════════════


// ─── Guests ────────────────────────────────────────────────────────
// /admin/guests + /admin/guests/[id]

GET guests:
  query all Guest ORDER BY lastName, firstName
  toBoolAll(rows, ...GUEST_BOOLS)
  return guests[]

POST guests:
  body = { firstName, lastName, email?, group?, ... }
  INSERT Guest { id: generateId(), ...body, rsvpStatus: "pending", createdAt, updatedAt }
  emit "guest:created"
  return 201 guest

PUT guests/[id]:
  find guest → 404 if missing
  dynamic UPDATE: only SET fields present in body
  return updated guest

DELETE guests/[id]:
  DELETE WHERE id
  IF rowsAffected = 0 → 404
  return { deleted: true }


// ─── Settings (Singleton) ──────────────────────────────────────────
// /admin/settings — no [id] route, always operates on single row

GET settings:
  row = queryOne SiteSettings LIMIT 1
  toBool(row, ...SETTINGS_BOOLS)
  mask sitePassword → "••••••••" (never expose actual password)
  return settings

PUT settings:
  body = { ...up to 49 fields }

  // Dynamic UPDATE with ~30 conditional fields
  Build SET clause: for each provided field, add to update list
  Special handling:
    - weddingDate → parse to ISO 8601
    - sitePassword → only update if value !== "••••••••" (skip masked value)

  IF no SiteSettings row exists → INSERT (first-run initialization)
  ELSE → UPDATE

  emit "settings:updated" { changedFields }
  return updated settings

// COMPLEXITY: 49-field singleton with masked password, date parsing,
// and conditional first-run INSERT makes this the most complex PUT handler


// ─── Content / Timeline Events ─────────────────────────────────────
// /admin/content + /admin/content/[id]

GET content:
  query TimelineEvent ORDER BY eventType, sortOrder, time
  return events[]

POST content:
  body = { title, time, description?, icon?, sortOrder?, eventType? }
  defaults: sortOrder=0, eventType="wedding-day"
  INSERT → return 201

PUT content/[id]:
  dynamic UPDATE on provided fields
  return updated event


// ─── FAQs ──────────────────────────────────────────────────────────
// /admin/faqs + /admin/faqs/[id]

GET faqs:
  query FAQ ORDER BY sortOrder
  toBoolAll(rows, ...FAQ_BOOLS)
  // Migration guard: try with isVisible column, fallback without
  return faqs[]

POST/PUT/DELETE: standard CRUD pattern


