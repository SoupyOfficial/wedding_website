//       goalAmount, raisedAmount, status, sortOrder


// ─── Photos ────────────────────────────────────────────────────────
// /admin/photos

GET photos:
  query all Photo + LEFT JOIN _PhotoToPhotoTag + PhotoTag
  Group tags by photo ID into tagsMap
  Attach tags[] to each photo
  return photos with tags

PUT photos/[id]:
  UPDATE caption, category, approved
  return updated photo

DELETE photos/[id]:
  IF photo has storageKey → provider.delete(storageKey)
  DELETE from _PhotoToPhotoTag junction WHERE photoId
  DELETE from Photo WHERE id
  return { deleted: true }

// Photo Tags:
GET photos/tags:
  query PhotoTag + LEFT JOIN count of photos per tag
  return tags with photoCount

POST photos/tags:
  body = { name, type, color?, sortOrder? }
  validate type in [event, person, date, location, custom]
  INSERT → catch unique violation → 409
  return 201 tag


// ─── Music / DJ ────────────────────────────────────────────────────
// /admin/music

GET music:
  Parallel fetch: songRequests[], djList[]
  toBoolAll on songRequests (SONG_BOOLS)
  return { songRequests, djList }

PUT music/songs/[id]:
  UPDATE SongRequest: approved, isVisible fields
  return updated request

DELETE music/songs/[id]:
  DELETE SongRequest WHERE id

POST music/dj:
  body = { songName, artist, listType, playTime? }
  validate listType in DJ_LIST_TYPES
  INSERT DJList
  return 201

PUT music/dj/[id]:
  dynamic UPDATE on DJList
  return updated

DELETE music/dj/[id]:
  DELETE DJList WHERE id

// Apple Music Import (admin only):
GET music/apple-music/import?check=true:
  return { configured: isAppleMusicConfigured() }

POST music/apple-music/import:
  body = { url, listType?, playTime?, skipDuplicates? }
  playlist = parsePlaylistUrl(url) → fetchPlaylist()
  IF skipDuplicates: load existing DJList, filter out matches
  bulk INSERT new tracks
  return { playlistName, totalTracks, addedCount, skippedCount, tracks[] }

// Apple Music Search (admin):
GET music/apple-music/search?q=term:
  // DUPLICATE: identical to public /music/search — same iTunes proxy
  fetch iTunes API, normalize, return results


// ─── Guest Book (Admin moderation) ─────────────────────────────────

GET admin/guest-book:
  query ALL GuestBookEntry (including isVisible=0)
  toBoolAll (GUESTBOOK_BOOLS)
  return entries[]  // admin sees all for moderation

PUT admin/guest-book/[id]:
  UPDATE isVisible field (approve/hide)
  return updated entry

DELETE admin/guest-book/[id]:
  DELETE WHERE id


// ─── Messages ──────────────────────────────────────────────────────
// /admin/messages — read-only (entries created via public /contact)

GET messages:
  query all ContactMessage ORDER BY createdAt DESC
  toBoolAll (MESSAGE_BOOLS)
  return messages[]

PUT messages/[id]:
  UPDATE isRead = 1 (mark as read)
  return updated message

DELETE messages/[id]:
  DELETE WHERE id


// ─── Features ──────────────────────────────────────────────────────
// /admin/features

GET features:
  return getFeatureFlags()  // merged DB + defaults

PUT features:
  body = { key, enabled }
  setFeatureFlag(key, enabled)
  return { success: true }
