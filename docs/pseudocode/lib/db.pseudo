                     Father-Daughter, Mother-Son, Bouquet Toss, Garter Toss,
                     Cake Cutting, Party Time, Last Song, Send Off]

DJ_LIST_TYPES      = ["must-play", "do-not-play"]
RSVP_STATUSES      = ["pending", "attending", "declined"]
TIMELINE_EVENT_TYPES = ["wedding-day", "pre-wedding", "post-wedding"]
