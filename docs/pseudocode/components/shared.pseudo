// UI PRIMITIVES (components/ui/)
// ═══════════════════════════════════════════════════════════════════

// ─── PageHeader ─────────────────────────────────────────────────────
// Props: title, subtitle?, className?
// Renders: H1 + SectionDivider + optional subtitle paragraph
// Used on all public pages

// ─── AdminPageHeader ────────────────────────────────────────────────
// Props: title, subtitle?, actions? (JSX)
// Renders: H1 + subtitle + action buttons row
// Admin-themed, used on all admin pages

// ─── Alert ──────────────────────────────────────────────────────────
// Props: type (success|error|warning|info), message, className?
// Color-coded background/border/text by type

// ─── Modal ──────────────────────────────────────────────────────────
// Props: title, children, onClose, maxWidth?
// Dark overlay + centered white box + close button (×) + scrollable children

// ─── LoadingState ───────────────────────────────────────────────────
// Props: message?
// Centered "Loading..." or custom message text

// ─── EmptyState ─────────────────────────────────────────────────────
// Props: icon?, title, subtitle?
// Centered icon + heading + description for empty lists

// ─── ConfirmButton ──────────────────────────────────────────────────
// Props: onConfirm, message, className, children
// Wraps browser window.confirm() — shows confirmation dialog before action

// ─── FilterBar<T> ───────────────────────────────────────────────────
// Props: filters: { label, value }[], active: T, onChange(T), variant?
// Generic typed filter UI: renders pill buttons or larger buttons
// Active state: gold highlight, inactive: transparent
// Used for: photo categories, DJ list types, guest filters
