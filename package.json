{
  "name": "wedding_website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "seed": "npx tsx prisma/seed.ts",
    "db:deploy": "npx tsx scripts/migrate-turso.ts",
    "hooks:install": "cp scripts/git-hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx tsx e2e/rotate-results.ts && npx playwright test && npx tsx e2e/rotate-results.ts",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:sync": "npx tsx e2e/sync-test-db.ts",
    "test:e2e:history": "npx tsx e2e/rotate-results.ts",
    "generate:types": "tsx scripts/generate-db-types.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@prisma/client": "^6.19.2",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^2.0.0",
    "autoprefixer": "^10.4.24",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.0",
    "jsonwebtoken": "^9.0.3",
    "next": "^14.2.35",
    "next-auth": "^5.0.0-beta.30",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.19",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/sharp": "^0.31.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-istanbul": "^3.2.4",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "jsdom": "^26.1.0",
    "prisma": "^6.19.2",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
